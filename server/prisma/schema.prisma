// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities   Activity[]
  actionPlans  ActionPlan[] @relation("AssignedPlans")
}

enum Role {
  ADMIN
  MANAGER
  AUDITOR
  USER
}

model Document {
  id         String   @id @default(uuid())
  name       String
  type       DocType
  standardId String
  status     DocStatus @default(PENDING)
  uploadDate DateTime  @default(now())
  reviewer   String?
  aiScore    Float?
  size       String
  version    String
  
  findings   AIFinding[]
  standard   Standard    @relation(fields: [standardId], references: [id])
}

enum DocType {
  POLICY
  PROCEDURE
  RECORD
  MANUAL
  CONTRACT
  REPORT
}

enum DocStatus {
  REVIEWED
  PENDING
  ISSUES_FOUND
  EXPIRED
}

model Standard {
  id          String   @id // e.g., 'BASC', 'ISO9001'
  name        String
  fullName    String
  description String
  color       String
  icon        String

  requirements Requirement[]
  documents    Document[]
  risks        Risk[]
  evidences    Evidence[]
  activities   Activity[]
}

model Requirement {
  id            String   @id @default(uuid())
  clause        String
  title         String
  description   String
  status        ReqStatus @default(PENDING)
  evidenceCount Int      @default(0)
  standardId    String
  
  standard      Standard @relation(fields: [standardId], references: [id])
}

enum ReqStatus {
  COMPLIANT
  NON_COMPLIANT
  PARTIAL
  PENDING
}

model AIFinding {
  id          String   @id @default(uuid())
  type        FindingType
  severity    Severity
  description String
  clause      String?
  documentId  String
  
  document    Document @relation(fields: [documentId], references: [id])
}

enum FindingType {
  GAP
  RECOMMENDATION
  RISK
  IMPROVEMENT
}

enum Severity {
  HIGH
  MEDIUM
  LOW
}

model Risk {
  id          String   @id @default(uuid())
  title       String
  description String
  category    String
  standardId  String
  probability Int
  impact      Int
  level       RiskLevel
  status      RiskStatus @default(OPEN)
  owner       String
  createdDate DateTime @default(now())
  updatedDate DateTime @updatedAt
  
  standard    Standard @relation(fields: [standardId], references: [id])
}

enum RiskLevel {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum RiskStatus {
  OPEN
  MITIGATED
  ACCEPTED
  CLOSED
}

model Evidence {
  id            String   @id @default(uuid())
  title         String
  description   String
  standardId    String
  clause        String
  type          EvType
  status        EvStatus @default(PENDING_REVIEW)
  uploadDate    DateTime @default(now())
  expiryDate    DateTime?
  
  standard      Standard @relation(fields: [standardId], references: [id])
}

enum EvType {
  DOCUMENT
  PHOTO
  RECORD
  REPORT
  CERTIFICATE
}

enum EvStatus {
  VALID
  EXPIRED
  PENDING_REVIEW
}

model ActionPlan {
  id            String   @id @default(uuid())
  title         String
  description   String
  type          PlanType
  status        PlanStatus @default(PENDING)
  priority      Severity
  assigneeId    String
  dueDate       DateTime
  createdDate   DateTime @default(now())
  progress      Int      @default(0)
  
  assignee      User     @relation("AssignedPlans", fields: [assigneeId], references: [id])
}

enum PlanType {
  CORRECTIVE
  PREVENTIVE
  IMPROVEMENT
}

enum PlanStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

model Activity {
  id          String   @id @default(uuid())
  action      String
  description String
  userId      String
  standardId  String?
  timestamp   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id])
  standard    Standard? @relation(fields: [standardId], references: [id])
}
